# ============================================================
# TorrenCloud All-in-One — Environment Configuration
# ============================================================
# Copy this file to .env, fill in the values, then run:
#   Linux/macOS:  ./run.sh
#   Windows:      .\run.ps1
# ============================================================

# -----------------------------------------------------------
# Database (PostgreSQL — internal to container, port 5432)
# -----------------------------------------------------------
POSTGRES_DB=torrenclo
POSTGRES_USER=torrenclo_user
POSTGRES_PASSWORD=<CHANGE_ME>

# -----------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------
JWT_SECRET=<CHANGE_ME_min_32_characters>
JWT_ISSUER=TorrenClou_API
JWT_AUDIENCE=TorrenClou_Client

# -----------------------------------------------------------
# Admin Credentials
# -----------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<CHANGE_ME>
ADMIN_NAME=Admin

# -----------------------------------------------------------
# NextAuth & Frontend API Configuration
# -----------------------------------------------------------
NEXTAUTH_SECRET=<CHANGE_ME_random_string>
NEXTAUTH_URL=http://localhost:47100
# API_PORT: Backend port (frontend will query this port on the same hostname)
# Only needed for docker-compose (separate services)
# Example: if frontend on :3000, set API_PORT=5000 to query :5000/api
# API_PORT=5000

# -----------------------------------------------------------
# Workers
# -----------------------------------------------------------
HANGFIRE_WORKER_COUNT=10

# -----------------------------------------------------------
# Grafana (http://localhost:47500)
# -----------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -----------------------------------------------------------
# Observability (all optional)
# -----------------------------------------------------------
# OBSERVABILITY_LOKI_URL=
# OBSERVABILITY_OTLP_ENDPOINT=
# OBSERVABILITY_ENABLE_PROMETHEUS=true
# OBSERVABILITY_ENABLE_TRACING=true
